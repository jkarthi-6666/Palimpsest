DATABASE_URL=postgresql://palimpsest:palimpsest@localhost:5433/palimpsest
QDRANT_URL=http://localhost:6333
EMBED_MODEL=nvidia/nemotron-3-embed-1b

# Copy this file to .env and replace the placeholder. .env is gitignored;
# never commit an NVIDIA API key.
NVIDIA_API_KEY=replace-with-your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Chat completion backend. Point these at NVIDIA or any OpenAI-compatible local
# server such as LM Studio. The model identifier is always read from this file.
LLM_BASE_URL=${NVIDIA_BASE_URL}
LLM_API_KEY=${NVIDIA_API_KEY}
LLM_MODEL=meta/llama-3.3-70b-instruct
